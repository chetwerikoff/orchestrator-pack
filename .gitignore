# Local AO config generated from the reusable example.
# Commit agent-orchestrator.yaml.example, not real target-repo configs.
agent-orchestrator.yaml
agent-orchestrator.*.yaml
!agent-orchestrator.yaml.example

# Secrets and credentials.
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
secrets/
private/

# AO runtime/session state. Keep committed material reusable only.
.ao/
.agent-orchestrator/

# Upstream source checkout is disposable/reference-only.
vendor/

# Dependency/build/test artifacts.
node_modules/
.pnpm-store/
.npm/
dist/
build/
coverage/
.out/
.cache/
.turbo/
.next/

# Logs, local scratch, generated ledgers/databases.
*.log
*.tmp
*.temp
*.bak
*.swp
*.sqlite
*.sqlite3
*.db
*.jsonl.local
scratch/
tmp/
temp/
worktrees/
target-repos/

# OS/editor noise.
.DS_Store
Thumbs.db
.vscode/
.idea/
*.code-workspace

# Claude Code session state (keep skills, ignore everything else).
.claude/*
!.claude/skills/

# Operator-local scratch: stray captures, backups, session state.
# Not synced to git; kept out of the working tree's tracked diff on purpose.
.local/

# Investigation reports and draft-review audit trails are local working
# artifacts, not committed history.
docs/investigations/
docs/issues_drafts/.review/

# Graphify code-graph working state (Issue #833): the isolated Python venv
# and the built graph output. Neither is committed -- see
# scripts/graphify/README.md for how to rebuild both on demand.
.graphify/
