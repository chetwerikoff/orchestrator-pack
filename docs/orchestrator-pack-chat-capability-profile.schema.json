{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/chetwerikoff/orchestrator-pack/main/docs/orchestrator-pack-chat-capability-profile.schema.json",
  "title": "orchestrator-pack standalone chat capability profile",
  "description": "Strict structure for transport and observation capability evidence. A profile is not task ownership, a lock, a lease, or write authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "repository",
    "profileKey",
    "createdAt",
    "updatedAt",
    "ownerOrLastUpdater",
    "capabilities"
  ],
  "properties": {
    "schema": {
      "const": "orchestrator-pack-chat-capability-profile/v1"
    },
    "repository": {
      "$ref": "#/$defs/repository"
    },
    "profileKey": {
      "$ref": "#/$defs/profileKey"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "ownerOrLastUpdater": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "capabilities": {
      "type": "object",
      "minProperties": 7,
      "maxProperties": 64,
      "propertyNames": {
        "allOf": [
          {
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
            "maxLength": 128
          },
          {
            "not": {
              "pattern": "(?:^|-)(?:receipt|ownership|takeover|claim|lease|lock)(?:-|$)"
            }
          }
        ]
      },
      "required": [
        "repository-read",
        "text-publication",
        "commit-tree-ref-publication",
        "issue-pr-create-update",
        "ci-runs-jobs-logs-read",
        "review-observation",
        "long-process-handling"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/capability"
      }
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fullName"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "fullName": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
          "minLength": 3,
          "maxLength": 200
        }
      }
    },
    "profileKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fingerprintVersion",
        "environment",
        "environmentDigest",
        "authPrincipal",
        "permissionClass"
      ],
      "properties": {
        "fingerprintVersion": {
          "const": 1
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "environmentDigest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "authPrincipal": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[^\\r\\n]+$"
        },
        "permissionClass": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "chatSurface",
        "runtimeClass",
        "connectors",
        "publicationTransports",
        "ciObservation",
        "reviewObservation"
      ],
      "properties": {
        "chatSurface": {
          "$ref": "#/$defs/canonicalToken"
        },
        "runtimeClass": {
          "$ref": "#/$defs/canonicalToken"
        },
        "connectors": {
          "$ref": "#/$defs/canonicalTokenArray"
        },
        "publicationTransports": {
          "$ref": "#/$defs/canonicalTokenArray"
        },
        "ciObservation": {
          "$ref": "#/$defs/canonicalToken"
        },
        "reviewObservation": {
          "$ref": "#/$defs/canonicalToken"
        }
      }
    },
    "canonicalToken": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "canonicalTokenArray": {
      "type": "array",
      "minItems": 1,
      "maxItems": 32,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/canonicalToken"
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "evidence",
        "testedAt",
        "knownLimits",
        "preferredFallback"
      ],
      "properties": {
        "status": {
          "enum": [
            "proven",
            "available-but-unproven",
            "unavailable",
            "degraded"
          ]
        },
        "evidence": {
          "type": "string",
          "minLength": 1,
          "maxLength": 8000
        },
        "testedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "noExpiryRationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "knownLimits": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "preferredFallback": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        }
      },
      "oneOf": [
        {
          "required": [
            "expiresAt"
          ],
          "not": {
            "required": [
              "noExpiryRationale"
            ]
          }
        },
        {
          "required": [
            "noExpiryRationale"
          ],
          "not": {
            "required": [
              "expiresAt"
            ]
          }
        }
      ]
    }
  }
}
