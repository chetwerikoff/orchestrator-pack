{
  "include": [
    "plugins/**/lib/**/*.ts",
    "plugins/**/bin/**/*.ts",
    "scripts/**/*.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "allowImportingTsExtensions": true
  },
  "exclude": [
    "plugins/**/tests/**",
    "scripts/**/*.test.ts",
    "scripts/**/*.spec.ts",
    "tests/**"
  ]
}
