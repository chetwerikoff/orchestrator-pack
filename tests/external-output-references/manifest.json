{
  "version": 1,
  "description": "Per-variant references for external-tool output used in pack trigger tests (Issue #223).",
  "commands": {
    "ao-worker-report": {
      "source": "ao report / ao acknowledge",
      "variantDir": "variants/ao-worker-report",
      "variantFromField": "reportState"
    },
    "gh-pr-open": {
      "source": "gh pr list --state open --json number,headRefOid,baseRefName (headCommittedAt derived)",
      "variantDir": "variants/gh-pr-open",
      "defaultVariant": "open"
    },
    "gh-pr-checks": {
      "source": "gh pr checks <n> --json name,state,bucket,link,startedAt,completedAt,workflow,description",
      "variantDir": "variants/gh-pr-checks",
      "defaultVariant": "representative-pr"
    },
    "ao-review-run": {
      "source": "ao review list <project> --json",
      "variantDir": "variants/ao-review-run",
      "variantFromField": "status"
    },
    "ao-status-session": {
      "source": "ao status --json --reports full (session row from data[])",
      "variantDir": "variants/ao-status-session",
      "defaultVariant": "working-no-runtime"
    }
  }
}
