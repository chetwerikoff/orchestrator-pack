def insert_after_test(source: str, title: str, insertion: str) -> str:
    marker = "  it('" + title + "', () => {"
    test_start = source.find(marker)
    if test_start < 0:
        raise SystemExit(f'test anchor not found: {title}')
    next_test = source.find("\n  it('", test_start + len(marker))
    if next_test < 0:
        suite_end = source.rfind("\n});")
        if suite_end < 0:
            raise SystemExit(f'test suite end not found after: {title}')
        next_test = suite_end
    return source[:next_test] + insertion + source[next_test:]

text = insert_after_test(
    text,
    'rejects a prose-only mention that replaces an executable workflow step',
    addition,
)
