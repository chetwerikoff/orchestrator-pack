    'sourcePath': 'scripts/verify.ps1',
    'sourceBlobSha': '6e1c57e8a8114e0e74618bb6e8129463ca4ae881',
    'spans': []
}
for name,start,end in [('Test-RequiredFile',105,115),('Test-ContractMarkers',117,144)]:
    fn=extract_fn(span_text,name)
    meta['spans'].append({'name':name,'startLine':start,'endLine':end,'sha256':hashlib.sha256(fn.encode()).hexdigest()})
