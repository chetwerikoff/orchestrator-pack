{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/chetwerikoff/orchestrator-pack/main/.github/orchestrator-pack-chat-capability-profile.schema.json",
  "title": "orchestrator-pack standalone chat capability profile",
  "description": "Strict structure for the JSON payload embedded in the canonical operational capability-profile Issue.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "repository",
    "profileKey",
    "createdAt",
    "updatedAt",
    "ownerOrLastUpdater",
    "capabilities"
  ],
  "properties": {
    "schema": {
      "const": "orchestrator-pack-chat-capability-profile/v1"
    },
    "repository": {
      "$ref": "#/$defs/repository"
    },
    "profileKey": {
      "$ref": "#/$defs/profileKey"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "ownerOrLastUpdater": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "capabilities": {
      "type": "object",
      "minProperties": 7,
      "maxProperties": 64,
      "propertyNames": {
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
        "maxLength": 128
      },
      "required": [
        "repository-read",
        "text-publication",
        "commit-tree-ref-publication",
        "issue-pr-create-update",
        "ci-runs-jobs-logs-read",
        "review-observation",
        "long-process-handling"
      ],
      "additionalProperties": {
        "$ref": "#/$defs/capability"
      }
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "fullName"
      ],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "fullName": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$",
          "minLength": 3,
          "maxLength": 200
        }
      }
    },
    "profileKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environmentToolFingerprint",
        "authPrincipal",
        "permissionClass"
      ],
      "properties": {
        "environmentToolFingerprint": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[^\\r\\n]+$"
        },
        "authPrincipal": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[^\\r\\n]+$"
        },
        "permissionClass": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        }
      }
    },
    "capability": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "evidence",
        "testedAt",
        "knownLimits",
        "preferredFallback"
      ],
      "properties": {
        "status": {
          "enum": [
            "proven",
            "available-but-unproven",
            "unavailable",
            "degraded"
          ]
        },
        "evidence": {
          "type": "string",
          "minLength": 1,
          "maxLength": 8000
        },
        "testedAt": {
          "type": "string",
          "format": "date-time"
        },
        "expiresAt": {
          "type": "string",
          "format": "date-time"
        },
        "noExpiryRationale": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "knownLimits": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        },
        "preferredFallback": {
          "type": "string",
          "minLength": 1,
          "maxLength": 4000
        }
      },
      "oneOf": [
        {
          "required": [
            "expiresAt"
          ],
          "not": {
            "required": [
              "noExpiryRationale"
            ]
          }
        },
        {
          "required": [
            "noExpiryRationale"
          ],
          "not": {
            "required": [
              "expiresAt"
            ]
          }
        }
      ]
    }
  }
}
