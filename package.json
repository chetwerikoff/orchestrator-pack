{
  "name": "orchestrator-pack",
  "private": true,
  "type": "module",
  "workspaces": [
    "plugins/*"
  ],
  "scripts": {
    "check:node-major": "node scripts/toolchain/check-node-major.mjs",
    "test": "node scripts/run-vitest-with-harness.mjs run",
    "test:watch": "node scripts/run-vitest-with-harness.mjs watch",
    "ts:smoke": "npm run check:node-major --silent && node --experimental-strip-types scripts/typescript-smoke.ts",
    "typecheck:foundation": "npm run check:node-major --silent && tsc -p tsconfig.json --noEmit",
    "lint:foundation": "npm run check:node-major --silent && node --experimental-strip-types scripts/toolchain/check-ts-policy.ts && node --experimental-strip-types scripts/toolchain/check-typescript-runtime-policy.ts",
    "check:typescript-runtime": "npm run check:node-major --silent && node --experimental-strip-types scripts/toolchain/check-typescript-runtime-policy.ts",
    "check:pwsh-test-growth": "npm run check:node-major --silent && node --experimental-strip-types scripts/toolchain/check-pwsh-test-growth.ts",
    "test:foundation": "npm run check:node-major --silent && vitest run --config scripts/toolchain/vitest-foundation.config.ts",
    "test:issue-900": "npm run check:node-major --silent && vitest run --config scripts/toolchain/vitest-foundation.config.ts scripts/toolchain/node22-runtime-policy.spec.ts",
    "test:issue-964": "npm run check:node-major --silent && vitest run --config scripts/toolchain/vitest-foundation.config.ts scripts/toolchain/chatgpt-browser-turn.test.ts scripts/toolchain/chatgpt-browser-turn.review-fixes.test.ts",
    "chatgpt-browser-turn": "npm run check:node-major --silent && node --experimental-strip-types scripts/chatgpt-browser-turn.ts",
    "gate-runner-selftest": "npm run check:node-major --silent && vitest run --config scripts/toolchain/vitest-foundation.config.ts scripts/gate-runner",
    "gate-census-generate": "npm run check:node-major --silent && node --experimental-strip-types scripts/gate-runner/census-generator.ts",
    "estate-cut:check": "npm run check:node-major --silent && node --experimental-strip-types scripts/estate-cut/manifest-generator.mjs --check",
    "test:issue-906": "npm run check:node-major --silent && vitest run --config scripts/estate-cut/vitest.config.ts",
    "test:contract-mutations": "npm run check:node-major --silent && node --experimental-strip-types scripts/pr2-foundation/contract-test-runner.ts"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "22.x"
  },
  "imports": {
    "#opk-kernel/*": "./scripts/kernel/*.ts",
    "#opk-toolchain/*": "./scripts/toolchain/*.ts"
  }
}
