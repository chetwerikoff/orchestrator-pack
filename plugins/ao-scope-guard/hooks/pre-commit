#!/usr/bin/env sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"

if [ -z "${AO_ISSUE_NUMBER:-}" ]; then
  echo "ao-scope-guard pre-commit: AO_ISSUE_NUMBER is not set; skipping scope check" >&2
  exit 0
fi

if command -v pwsh >/dev/null 2>&1; then
  PS_BIN="pwsh"
else
  PS_BIN="powershell.exe"
fi

"$PS_BIN" -NoProfile -ExecutionPolicy Bypass -File "$ROOT/plugins/ao-scope-guard/hooks/pre-commit.ps1"
