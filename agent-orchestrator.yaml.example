$schema: https://raw.githubusercontent.com/ComposioHQ/agent-orchestrator/main/schema/config.schema.json
# Legacy-import example / migration fixture for AO 0.10.3.
#
# This file is NOT the live orchestrator-pack policy source. AO 0.10.3 does not apply
# the former orchestratorRules, reactions, runtime, workspace, tracker, SCM, or rules
# fields as live pack-review policy. Configure supported live project settings through
# AO ProjectConfig and operate pack review through docs/pack-review-runbook.md.
#
# Worker instructions are delivered by tracked AGENTS.md. Pack side processes read
# their own code, environment, and local stores; they do not obtain the review contract
# from this YAML.

port: 3000

defaults:
  agent: cursor
  orchestrator:
    agent: cursor
  worker:
    agent: cursor
  notifiers: [desktop]

projects:
  example:
    repo: your-org/your-repo
    path: /home/you/projects/your-target-repo
    defaultBranch: main
    sessionPrefix: ex
    orchestrator:
      agent: cursor
      agentConfig:
        permissions: permissionless
    worker:
      agent: cursor
      agentConfig:
        permissions: permissionless
    # Compatibility fixture for import/migration tooling only. This literal is not
    # current AO or pack-review policy and must not be copied into a live project.
    orchestratorRules: |
      LEGACY MIGRATION FIXTURE ONLY — authoritative review behavior is in docs/pack-review-runbook.md.
      NAMED REVIEW_COMMAND (historical compatibility shape):
        pwsh -NoProfile -File scripts/invoke-pack-review.ps1 --repo-root . --base origin/main

# Current pack-review authority:
# - docs/pack-review-runbook.md: complete operator/runtime contract
# - AGENTS.md: worker instructions
# - scripts/pack-review-runner.ts: review start and run lifecycle
# - scripts/invoke-pack-review.ps1: reviewer wrapper
# - PACK_REVIEWER: codex/claude selector inherited by the pack supervisor
#
# AO review HTTP API, ao review submit, and project reviewer configuration still exist
# upstream in AO 0.10.3, but orchestrator-pack does not use them as invocation, status,
# delivery, fallback, dual-write, or merge-authority paths.
