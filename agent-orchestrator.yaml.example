$schema: https://raw.githubusercontent.com/ComposioHQ/agent-orchestrator/main/schema/config.schema.json
# Linux-first Composio Agent Orchestrator example for orchestrator-pack.
# Copy to agent-orchestrator.yaml and edit the project block before running AO.
# Supported on Ubuntu / WSL2 Ubuntu (pwsh 7+). Native Windows is not a runtime target.

port: 3000

defaults:
  runtime: process        # Linux: native process runtime; tmux optional if you prefer AO tmux mode.
  agent: cursor           # Primary agent plugin: Cursor CLI.
  orchestrator:
    agent: cursor         # Planner/orchestrator role: Cursor CLI.
  worker:
    agent: cursor         # Coding/worker role: Cursor CLI.
  workspace: worktree
  notifiers: [desktop]

# Orchestrator wake (issues #39 / #59): webhook listener + heartbeat backstop.
# AO webhook POSTs urgent/action notifications to the local listener; a separate
# heartbeat process delivers periodic `ao send` nudges during event silence.
# Start scripts/orchestrator-wake-supervisor.ps1 (listener + heartbeat + reconcile children),
# scripts/review-trigger-reconcile.ps1, and other reconcile loops alongside `ao start` — see
# docs/orchestrator-wake-runbook.md and docs/orchestrator-autoloop-go-live.md.
notifiers:
  webhook:
    plugin: webhook
    url: http://127.0.0.1:17487/ao-wake
    retries: 1
    retryDelayMs: 500

notificationRouting:
  urgent:
    - desktop
    - webhook
  action:
    - desktop
    - webhook
  warning:
    - desktop
  info:
    - desktop

projects:
  example:
    repo: your-org/your-repo
    path: /home/you/projects/your-target-repo
    defaultBranch: main
    sessionPrefix: ex
    tracker:
      plugin: github      # Tasks are GitHub Issues by default/explicit config.
    scm:
      plugin: github
    orchestrator:
      agent: cursor
      agentConfig:
        permissions: permissionless
        env:
          AO_AUTONOMOUS_ORCHESTRATOR_SURFACE: "1"
          # Out-of-band real-binary resolution (gitignored). Copy docs/autonomous-real-binaries.example.json
          # to .ao/autonomous-real-binaries.json with pack scripts/git-real-binary + gitSystemBinary host path
          # — never point git at /usr/bin/git directly and never expose AO_REAL_BINARY/GIT_REAL_BINARY.
          # Prepend pack scripts/ so orchestrator turns resolve `ao`, `git`, and `gh` to
          # scripts/ao + scripts/git + scripts/gh (always-REST inventory reads for gh; Issue #431).
          # Keep /usr/bin and /bin after scripts/ so shim shebangs (#!/usr/bin/env bash) and helpers
          # (pwsh, python3, dirname, readlink) resolve; BASH_ENV bootstrap prepends scripts/,
          # maps live AO_TMUX_NAME *orchestrator* when agentConfig.env does not reach tmux,
          # and sources scripts/autonomous-bash-env.sh for bash-turn absolute-git interposition.
          # Do not set POSIXLY_CORRECT or SHELLOPTS=posix here — bash disables BASH_ENV when either is active.
          BASH_ENV: /home/you/projects/orchestrator-pack/scripts/autonomous-orchestrator-surface-bootstrap.sh
          # Optional explicit slug for pack gh reads (--repo / GH_REPO beat git-derived slug).
          # When unset, surface bootstrap exports GH_REPO from the checkout origin (Issue #599).
          # GH_REPO: chetwerikoff/orchestrator-pack
          PATH: /home/you/projects/orchestrator-pack/scripts:/home/you/.local/bin:/usr/local/bin:/usr/bin:/bin
          # Optional shared GitHub API governor (Issue #585). Off by default until participation probe passes.
          # GH_GOVERNOR_ENABLED: "1"
    worker:
      agent: cursor
      agentConfig:
        permissions: permissionless
    agentRulesFile: prompts/agent_rules.md
    orchestratorRules: |
      Use GitHub Issues as the task source of truth.
      Plan from open GitHub Issues, spawn coding workers with the Cursor CLI agent,
      and keep PRs linked back to their source issues with Closes #N or Fixes #N in the PR body.
      Do not use Vibe Kanban or Linear for this project unless explicitly reconfigured.
      Do not add unsupported reviewer fields to this YAML — drive review through CLI.

      REVIEW DRIVING — AO 0.10 does not auto-trigger Codex review on PR open.
      Live procedure: prompts/agent_rules.md + side-process scripts (orchestratorRules below is legacy-import reference only).
      The orchestrator and reconcile loops jump the gaps via ao-review run / Get-AoReviewRuns.

      Always invoke review through the pack wrapper (Issue #9 / NO_FINDINGS contract).
      Never run review without the pack REVIEW_COMMAND wrapper — built-in Codex
      wraps clean-review prose as a false `severity: warning` finding.

      PACK_REVIEWER (operator selector — single source of truth; set before ao start):
        Recognized values: codex | claude. Dispatches to tracked wrappers only (not REVIEW_COMMAND).
        Unset or unrecognized PACK_REVIEWER: invoke-pack-review.ps1 exits non-zero and runs no reviewer (fail-closed; no Codex default).
        Switch reviewers by changing PACK_REVIEWER only — do not edit REVIEW_COMMAND. See docs/reviewer-switch-runbook.md.
        Gitignored .ao paths are deprecated; never use .ao/ in REVIEW_COMMAND.
      NAMED REVIEW_COMMAND (reviewer-agnostic entrypoint; run from the reviewed repo root):
        pwsh -NoProfile -File scripts/invoke-pack-review.ps1 --repo-root . --base origin/main

      RUNTIME INVOCATION (shell only — do NOT embed --command in orchestratorRules):
        At review time: ao-review run <worker-session-id>  (scripts/ao-review.ps1 shim → POST .../reviews/trigger)
        REVIEW_COMMAND is configured in project review settings / operator shell — not re-pasted here.
        Discover/idempotency: Get-AoReviewRuns fan-out (GET /api/v1/sessions/{id}/reviews) or ao-review list <session-id> --json.
        Do not add double-quote characters inside this orchestratorRules literal.

      COMMAND DISCIPLINE — non-negotiable at shell time:
        Copy REVIEW_COMMAND verbatim into --command. Quote the value per your shell when needed.
        FORBIDDEN alternate commands: plugins/ao-codex-pr-reviewer/bin/review.ps1 without invoke-pack-review.ps1; per-reviewer run-pack-review*.ps1 as REVIEW_COMMAND; cmd /c npm ci && …; bare cmd.exe; inventing npm ci preflight chains; bare ao-review without REVIEW_COMMAND configured (built-in Codex path).
        On failed or cancelled runs, read latestRun.body (failure detail) before any retry; never treat findingCount 0 as up_to_date.
        Before merge or reporting review passed, run scripts/orchestrator-diagnose.ps1 -Strict (live) or scripts/invoke-pack-review-strict-gate.ps1 on fixtures in CI, and confirm the latest run for the PR head is up_to_date — not failed with zero findings.

      EMPTY REVIEW TRAP — failed or cancelled with findingCount 0 is NEVER up_to_date:
        AO may list 0 open findings while status is failed — that means the reviewer command crashed or Codex/Claude exited non-zero, not a clean NO_FINDINGS review.
        Always read latestRun.body (failure detail) from Get-AoReviewRuns first. Common causes: Codex usage limit (set PACK_REVIEWER=claude per docs/reviewer-switch-runbook.md), missing PACK_REVIEWER, missing npm preflight (forbidden bare review.ps1), or selector mismatch (failure detail shows a different wrapper than PACK_REVIEWER).
        Do not tell the worker review is complete when only failed runs exist for the current head. Retry once with the live REVIEW_COMMAND after fixing the cause; if still failed, escalate to the operator.

      WALL-CLOCK NOTE. Targets such as ~2 minutes for worker acknowledgement and
      ~3 minutes after ping before respawn are operator guidance applied on the next
      orchestrator turn, not independently enforced timers. There is no background
      watchdog. The 30-minute AO report-stale reaction is a long-tail backstop only.

      REQUIRED CI (CI green) — same definition as prompts/agent_rules.md:
        Preferred: GitHub required status checks for the PR base branch when branch
        protection lists them.
        Fallback: when no required checks are configured, all checks on the PR head
        that belong to this pack merge contract — scope-guard workflow jobs
        Verify orchestrator-pack structure, PR scope guard, Run pack contract tests,
        Self-architect lint — not every optional third-party check unless the repo
        already treats it as merge-blocking.

      CI FAILURE DISCIPLINE (Issues #109/#283/#342). A failing GitHub check does NOT
      by itself schedule an orchestrator turn. Pack rules apply on the next orchestrator
      turn only (worker ao report, webhook wake, operator activity). If nothing creates
      a turn, reactions.report-stale (~30 minutes) and the unconditional reactions.ci-failed
      instant backstop remain upstream — not replaced by pack prose.

      ENQUEUE-ONLY ci-failed + DELIVERY-TIME LIVE-STATE EVALUATION (#342). The built-in
      reactions.ci-failed reaction records a pending episode (phase=record) keyed to the
      full episode tuple {repo, PR number, head SHA, aggregate red-period discriminator,
      active notification targetId + targetGeneration}. It does NOT decide SEND at fire time.
      A supervised reconcile loop evaluates each eligible pending episode once against live
      PR-owner worker state (ao status sessions + open PR heads):
        pwsh -NoProfile -File scripts/ci-failure-notification-reconcile.ps1
      Default cadence: 1 minute. State/store: AO_CI_FAILURE_NOTIFICATION_STORE or
      %TEMP%\orchestrator-ci-failure-notification. Eligibility boundary: at least one
      reconcile tick after enqueue (never evaluate in the enqueue tick). Freshness SLA:
      max-eligible-evaluation-age ≤ 3× reconcile interval and < report-stale (~30m).

      OPERATOR REFERENCE — mechanical CI-failure notification pair (Issues #283/#342/#645).
      Red-CI worker delivery is owned by supervised side-process children, not orchestratorRules
      on AO 0.10.2+. Copy this block into live yaml only as documentation; wiring is via
      agent-orchestrator.yaml.example reactions + sideProcessChildren (not orchestrator turn prose).

      Record path (phase=record): reactions.ci-failed enqueues a pending episode via
        pwsh -NoProfile -File scripts/ci-failure-notification-reaction.ps1
      Evaluate + send path: supervised reconcile evaluates live workerState and sends via
        pwsh -NoProfile -File scripts/ci-failure-notification-reconcile.ps1
      Low-level helper (reaction/reconcile invoke this; operators rarely call directly):
        pwsh -NoProfile -File scripts/ci-failure-notification.ps1 -Mode record
        pwsh -NoProfile -File scripts/ci-failure-notification.ps1 -Mode evaluate

      Episode identity uses the full episode key tuple {repo, PR number, head SHA, aggregate
      red-period discriminator, active notification targetId + targetGeneration}. The failing
      required-check set is message context only, never part of the episode identity.
      Feed JSON containing the episode key, workerState {sessions, openPrs} from
      ao status --json --reports full + gh pr list, minimized reaction.action_succeeded
      events with reactionKey=ci-failed, and exact-key intent-token state (excluding
      the episode's own pending record/claim from dedup/intent suppressors).
      The wrapper timeout/error contract emits phase=diagnostic hard failures;
      repeated helper errors are operator-visible via reconcile health.

      Reconcile delivery-time rules (authoritative at evaluate/send, not at reaction fire):
        Terminal_action when phase=terminal is SEND or SUPPRESS only. Missing/incompatible
        workerState is a non-terminal hard failure (re-evaluable next tick).
        SUPPRESS when the predicate binds a reaction.action_succeeded event with
        reactionKey=ci-failed and action=send-to-agent to the full episode identity
        (excluding own record). Notify-only ci-failed reactions (action: notify) record
        pending episodes but do not prove worker delivery and MUST NOT suppress the
        reconcile ping. Also SUPPRESS when the live PR-owning worker session is in
        fixing_ci and passes liveness (suppressed-live-worker), when no live owner exists
        (abandoned-no-live-owner), when the episode is superseded (abandoned-superseded),
        or when an exact episode-keyed orchestrator intent token already owns the ping.
        working and pr_created do NOT suppress. A reaction/intent for an earlier head,
        earlier red-period, or superseded session MUST NOT suppress the active session's ping.
        SEND uses strict outbox: claim/preflight → pre-submit revalidation against live
        workerState → reserve submit-intent → ao send + Register-WorkerMessageDispatch.
      Audit lines use phase=record|diagnostic|terminal; only phase=terminal is authoritative.

      Startup / operator adoption gate (machine-checkable on live gitignored yaml):
        pwsh -NoProfile -File scripts/check-ci-failure-notification-adoption.ps1
      reactions.ci-failed is enabled only when workerState wiring AND durable submit-ack
      (#232 dispatch journal) are both present; otherwise degraded health disables only
      this reaction — never the whole orchestrator.

      The dominant ordering closed here is reaction-first for dedup: the orchestrator defers to the
      observable ci-failed reaction send. Live fixing_ci suppression closes the reproduced ~60s gap
      via delivery-time evaluation, not episode-key report binding.

      Operator target: within ~3 minutes after the next orchestrator turn that observes
      red CI — NOT within ~3 minutes of CI failure wall-clock. Op-6 class: catching turn
      was worker ready_for_review while CI still red; orchestrator should have pinged then.

      RESIDUAL RISK (gated + silently idle). Worker never reports ready_for_review on red
      CI but stays idle in fixing_ci with no commits and no further reports — no turn,
      so pack rules cannot ping. Expect only report-stale (~30 min), reactions.ci-failed,
      or operator ao send / kill-respawn per docs/orchestrator-recovery-runbook.md.

      STATE-DERIVED CI-GREEN WORKER WAKE (Issue #191 — separate process, ao send only).
      AO 0.9.x has no CI-green/CI-success reaction key for send-to-agent (reactions only
      expose ci-failed, changes-requested, report-stale, approved-and-green→notify). The
      fast path is a dedicated reconciliation loop outside the LLM orchestrator turn:
        pwsh -NoProfile -File scripts/ci-green-wake-reconcile.ps1
      Default cadence: 1 minute (worst-case green-observed → ao send ~60s poll + 1m tick,
      far below report-stale ~30m). Override with AO_CI_GREEN_WAKE_RECONCILE_INTERVAL_MINUTES
      or -IntervalMinutes. State file: AO_CI_GREEN_WAKE_RECONCILE_STATE or
      %TEMP%\orchestrator-ci-green-wake-state.json.
      Each tick (level/state-derived, not edge-only):
        1. gh pr list --state open --json number,headRefOid
        2. gh pr checks <n> --json name,state,bucket,link,startedAt,completedAt,workflow,description per PR — required CI per REQUIRED CI above
        3. ao status --json --reports full — linked worker session + report states
        4. For each open PR whose required CI is currently green, whose linked worker is
           runtime alive, head-owning, and pre-hand-off (fixing_ci / working / pr_created
           with no ready_for_review or addressing_reviews accepted on that head), and
           not yet nudged for this green transition: pre-send recheck on one snapshot,
           then ao send continue-hand-off message to that session id only
      Transition identity and dedupe live in the state file (survives sender restart;
      new red/pending→green on the same head SHA is a new transition). Record dedupe only
      after a successful send to a confirmed-live owner; failed/stale sends consume no slot.
      Does not recover dead workers (#98) — reduces how often respawn is needed.
      Safety (PR #97): never ao spawn, never --claim-pr, never ao session kill from this
      process. Does not alter approved-and-green or merge rules. reactions.report-stale and
      reactions.ci-failed remain upstream backstops (additive fast path, not a replacement).
      Verification:
        pwsh -NoProfile -File scripts/ci-green-wake-reconcile.ps1 -Once -DryRun

      DEAD WORKER RECONCILE (Issue #593 — assigned-task recovery only, default-OFF).
      Detects capture-backed death evidence for workers with unfinished bound issue/PR
      and may invoke scripts/invoke-worker-recovery.ps1 -Trigger reconcile_dead_worker
      when allowReconcileDeadWorkerRespawn is explicitly enabled in docs/autonomous-respawn-policy.json
      and all enablement gates pass. Never plans new work from open issues or the GitHub queue (assigned-task only). operator kill/
      shutdown and project-level shutdown windows suppress respawn. Uncaptured event shapes
      and ambiguous task state fail closed to audit-only. Storm bounds: per-key retry with
      suggested defaults 3 attempts, 60s initial exponential backoff with jitter, concurrency
      cap 1 (operator-tunable in policy JSON).
        pwsh -NoProfile -File scripts/dead-worker-reconcile.ps1
      State file: AO_DEAD_WORKER_RECONCILE_STATE or
      %TEMP%\orchestrator-dead-worker-reconcile-state.json.
      Safety: invokes only the #522 recovery entrypoint with caller-proved
      -ProbedDeadEvidence; never raw ao spawn from this loop.
      Verification:
        pwsh -NoProfile -File scripts/dead-worker-reconcile.ps1 -Once -DryRun


      See docs/orchestrator-autoloop-go-live.md and docs/migration_notes.md.

      MERGED PR — REVIEW LOOP TERMINAL (Issue #54). On EVERY orchestrator turn,
      BEFORE autonomous review-loop reads below, for each PR that has entries in
      Get-AoReviewRuns fan-out or an open worker session with a PR ref:
        Verify that PR merge state on GitHub (e.g. gh pr view <n> --json state,mergedAt).
        Key off the linked PR merge state, NOT solely ao status session merged or
        terminated — merge cleanup may kill the worker session while code-reviews/
        runs persist, so session-only checks miss this case. A visible merged or
        terminated worker session is sufficient but not necessary.

      Runs with no prNumber on the run record: resolve merge state via the run's
      linkedSessionId in ao status --json (match name, sessionId, or id on the
      linked worker session), then gh pr view on that session's PR — not solely a
      prNumber field on the run. When that linked worker PR is merged on GitHub,
      treat the run as terminal the same as runs that carry prNumber. When merge
      state cannot be resolved to a specific merged PR (linked session missing from
      ao status, restored under an unmatched session id, or PR metadata missing or
      ambiguous), fail closed to inaction — no new review round,
      no worker-lifecycle action; surface the run for the operator rather than guess.

      When the linked worker PR is merged on GitHub (human merge per repo policy):
        Treat all AO-local review runs for that PR as historical, not queue work.
        MUST NOT re-trigger delivery for any run linked to that PR (including prNumber-less
        runs resolved via linked session above).
        MUST NOT ao-review run for a new round on that PR.
        MUST NOT ao send ping, ao session kill, or ao spawn --claim-pr for review-loop
        purposes on that PR.
        MUST NOT treat changes_requested or up_to_date runs for that PR as blocking
        other work or as requiring autonomous-loop recovery.
        Linked PR merged is an additional EXIT for waiting_worker_review_response
        (see EXIT list below) — leave that state; do not ping or respawn for review.
        MAY proceed to other open issues and PRs normally.

      AO 0.9.x does not cancel or archive review runs on PR merge; stale dashboard
      cards are expected until upstream adds cancel or outdate-on-merge. Pack policy
      is orchestrator inaction and operator docs — not hand-editing code-reviews/ JSON.
      There is no ao-review cancel CLI today; see docs/orchestrator-recovery-runbook.md.

      AUTONOMOUS REVIEW LOOP — drive review→fix without waiting for a human to type
      review or loop. On every orchestrator turn after CI failure discipline above,
      while any open PR has an active review path, read these BEFORE any other planning
      work:
        Get-AoReviewRuns fan-out (or ao-review list per session)
        ao status --json --reports full
        ao events list --json

      REVIEW RUN STATUSES (AO 0.10 — normalized from Get-AoReviewRuns / GET /sessions/{id}/reviews):
        changes_requested (undelivered) — run finished; deliveredAt is null (operator/diagnostic only on 0.10).
          AO auto-delivers on submit; do not ao-review send (REMOVED). Use review-finding-delivery-confirm.ps1 (#171).
        changes_requested (delivered) — deliveredAt set, deliveredFindingCount > 0; findings with worker.
          Any run in this state is in waiting_worker_review_response until an exit
          condition fires (findings already delivered — do not re-trigger send).
        up_to_date — findingCount: 0 for that run's target SHA (clean / NO_FINDINGS).
        queued / preparing / running — review in flight; poll on next tick.
        outdated — superseded by a newer worker commit; trigger ao-review run when head ready.
        failed / cancelled — inspect latestRun.body (failure detail) from Get-AoReviewRuns;
          NEVER treat as up_to_date when findingCount is 0; NEVER report or infer Codex review
          passed when status is failed or cancelled; notify human or retry once after reading failure detail.

      Do NOT invent statuses — use producer-normalized values only (docs/review-producer-contract.mjs).

      CLEANLINESS FROM COUNTS ONLY. A review is up_to_date only when Get-AoReviewRuns shows
      up_to_date with findingCount: 0 for the current PR head. changes_requested is NOT up_to_date.
      findingCount 0 on failed or cancelled runs is NOT up_to_date. Never read or
      pattern-match finding body prose (NO_FINDINGS contract).

      SCRIPT-OWNED ROUTINE REVIEW (Issue #625 — operator reference). On AO 0.10 the LLM
      orchestrator turn does NOT start or drive routine ao-review run rounds. Covered-head,
      head-ready, and claim procedures belong to review-trigger-reconcile.ps1,
      review-trigger-reeval.ps1, and orchestrator-wake-listener.ps1. Exception-only LLM
      handling (contested protected finding E7, escalation wakes): issue #641 — pointer only.
      Manual operator ao-review run remains outside the automated claim.

      REVIEW RUN IDEMPOTENCY (Issue #98, widened Issue #189 — additive to EMPTY REVIEW TRAP).
      Before calling ao-review run for a worker session, read Get-AoReviewRuns and the
      current PR head sha (from gh pr view or the worker PR ref). A head SHA is covered —
      do not spawn a new run — when any run matches the SAME prNumber linkage AND the EXACT
      normalized head SHA (targetSha, case-insensitive) and is in-flight (queued, preparing,
      running, reviewing) OR covered terminal (up_to_date, changes_requested). A run on
      the same SHA for a different PR does NOT count as coverage. A run on the same PR with a
      different targetSha does NOT count as coverage for the current head. Only a head with no
      run at all, or whose only runs on that PR+head are outdated, may use the plain uncovered
      start path.

      FAILED / CANCELLED ON CURRENT HEAD (not covered — not plain uncovered). A failed or
      cancelled run on the current head is NOT a covered terminal status (never treat
      findingCount: 0 on failed as clean). Do not start a new run through the plain uncovered
      path; follow EMPTY REVIEW TRAP: read latestRun.body (failure detail), retry at most once after
      diagnosis, escalate otherwise.

      AUTOMATED REVIEW-START CLAIM (Issue #267, closes the #189/#207/#235 concurrent
      window). Every automated starter surface must acquire the shared machine-local
      review-start claim keyed by (prNumber, full normalized head SHA) before ao-review run:
      review-trigger-reconcile.ps1, orchestrator-wake-listener.ps1, review-trigger-reeval.ps1,
      and future noninteractive starters. The claim is an atomic cross-process
      test-and-set and stays effective until a covering run record is visible or a terminal
      outcome is recorded. Claim storage failure, unreadable/partial records, short SHAs,
      divergent SHA normalization, anomalous timestamps, or unknowable registration state
      fail closed with a visible escalation — never claim unavailable / proceed anyway.
      Losing surfaces log claim-skip with the key and restart-correlatable holder identity.
      Operator-invoked manual ao-review run remains outside the claim; automation treats a
      visible manual run record as coverage, while an operator racing inside AO registration
      lag is the accepted manual residual.

      PRE-RUN COVERAGE RE-CHECK / HEAD-READY RE-CHECK INSIDE THE CLAIM. After acquiring the claim and
      immediately before emitting ao-review run, re-read Get-AoReviewRuns and re-apply
      the covered-head predicate above with the smallest gap between read and run. If the
      head became covered between the turn's first observation and this re-check, abort and
      terminalize the claim as recheck-aborted. A stalled claimant that lost ownership to
      stale recovery must abort at the final ownership fence instead of starting.

      HEAD READY FOR REVIEW (Issue #195 — one predicate for all review-trigger paths).
      Before any automated ao-review run (review-trigger-reconcile.ps1,
      review-trigger-reeval.ps1, orchestrator-wake-listener.ps1 — not LLM turns), evaluate
      failed/cancelled on the current head FIRST (EMPTY REVIEW TRAP —
      never the plain uncovered-ready path). Then a PR head SHA is ready for review only when
      ALL hold on one consistent snapshot:
        - latest accepted worker report for that exact current head SHA is ready_for_review
          (a ready_for_review for an earlier head does not authorize a later head — reuse #186
          current-head-at-report-time semantics);
        - required CI on that head (same Required CI definition as prompts/agent_rules.md) is
          green or genuinely pending/queued against a known required-check set — explicitly NOT
          red/failing and NOT missing/unknown/unresolvable (red defers; missing routes to the
          degraded-CI orchestrator branch below);
        - the head is not already covered per REVIEW RUN IDEMPOTENCY (#189); and
        - no failed/cancelled run on the current head awaits EMPTY REVIEW TRAP handling.
      Uncovered-but-not-ready heads are left alone: no review run and no worker-lifecycle
      action from the reconciler. Defer, never drop — report-stale and ping/respawn backstops
      still reach idle/dead workers; #191 CI-green wake speeds pre-hand-off re-engagement.
      Worker degraded-CI hand-off (#186 evidence-backed escalation, not ready_for_review)
      routes to the orchestrator/reconciler degraded-CI branch — bounded re-attempts to resolve
      required-check visibility, then observable operator escalation — not generic
      uncovered-not-ready worker-liveness handling. PRE-RUN HEAD-READY RE-CHECK widens #189:
      immediately before ao-review run, re-read current head SHA, latest accepted report,
      required-CI state, and coverage; abort if the predicate no longer holds. Mechanical
      implementation: docs/review-head-ready.mjs (shared with review-trigger-reconcile.ps1
      and docs/review-orchestrator-loop.mjs).

      STALE REVIEWER WORKSPACE (Issue #98). Before ao-review run when the prior attempt for
      the same PR head failed with failure detail containing worktree add and already
      exists, or when retrying after a failed reviewer infra run, run from the pack repo root:
        pwsh -NoProfile -File scripts/reviewer-workspace-preflight.ps1 -RepoRoot .
      That removes an orphan code-reviews/workspaces path so AO git worktree add can succeed.
      See docs/orchestrator-recovery-runbook.md (Orphan review run after worker respawn).

      ROUTINE REVIEW TRIGGER (script-owned — operator reference prose; NOT an LLM turn
      checklist on AO 0.10). Routine review rounds are started by side-process scripts
      named above — the LLM orchestrator turn does not start or drive them. The block
      below documents legacy import / operator reference only. Historical claimed entry
      point (non-routine — not the 0.10 default path):
        pwsh -NoProfile -File scripts/invoke-orchestrator-claimed-review-run.ps1 `
          -SessionId <worker-session-id> -PrNumber <pr-number> [-EventHeadSha <wake-or-report-sha>]
      Process-boundary enforcement (fail-closed): autonomous orchestrator sessions set
      AO_AUTONOMOUS_ORCHESTRATOR_SURFACE=1, resolve real ao/git out-of-band via
      .ao/autonomous-real-binaries.json (never turn-visible AO_REAL_BINARY/GIT_REAL_BINARY),
      and prepend pack scripts/ to PATH so `ao`, `git`, and `gh` resolve to pack shims (deny spawn and
      direct tree-mutating git; #318 review-run gate + #324 spawn/git boundary);
      only the claimed entry point may launch review runs. Gate capability markers:
      orchestrator-claimed-review-run/v1 and autonomous-orchestrator-boundary/v1.
      Command-runtime bootstrap (refuses command turns when tools/PATH are incomplete):
      pwsh -NoProfile -File scripts/orchestrator-command-runtime-preflight.ps1
      (command-runtime-bootstrap/v1; also invoked from autonomous-orchestrator-surface-bootstrap.sh).
      Recovery-boundary: command-runtime failures route to Issue #522/#527 — no ad hoc cleanup here.
      Preflight (refuses autonomous starts when stale): pwsh -NoProfile -File
      scripts/orchestrator-review-start-preflight.ps1. Side-effect-safe live probe after
      ao stop / ao start: invoke-orchestrator-claimed-review-run.ps1 -Probe -DryRun (sentinel
      PR 999999 — must record covered-head denial, not merely head-resolution refusal).
      Manual operator override (outside autonomous surface): scripts/invoke-manual-review-run.ps1
      (emits advisory warning on covered/pending heads; does not acquire the autonomous gate).
      Prose REVIEW RUN IDEMPOTENCY below remains guidance; Issue #318 gate is authoritative
      for autonomous starts. Do not wait for operator words review or loop.
      Script-owned starters remain authoritative — review-trigger-reconcile.ps1 converges
      from GitHub + review list state even when reports are missing and the LLM orchestrator
      session is idle.

      EVENT-DRIVEN REVIEW TRIGGER (Issue #207 — wake listener, review-run only). On
      merge.ready (approved-and-green completion wake), orchestrator-wake-listener.ps1
      evaluates HEAD READY FOR REVIEW (#195), acquires the shared review-start claim, then
      may ao-review run before forwarding the merge-intent wake. Merge handling must re-read
      run state (mergeable=false annotation when review is in-flight). Processing bound: 5s
      wake-to-run decision (listener-local). Side-effecting supervised child; additive to
      periodic reconcile below and heartbeat — not a replacement. Safety: never ao spawn,
      --claim-pr, ao session kill, ao send, or merge from this path — only ao-review run.

      REVIEW-STATUS READER (Issue #611): worker report state comes from report-full snapshots only — `$.data[]` session rows with `reports[*]` via `Get-AoStatusSessionsWithReports` / audit-backed `.agent-report-audit`, never plain `ao session ls` or empty `reports: []` without naming the non-report-full source.

      STATE-DERIVED REVIEW TRIGGER (Issue #163 — separate process, review-run only). A
      low-frequency reconciliation loop runs outside the LLM orchestrator turn loop:
        pwsh -NoProfile -File scripts/review-trigger-reconcile.ps1
      Default cadence: 10 minutes (tens of minutes). Override with
      AO_REVIEW_TRIGGER_RECONCILE_INTERVAL_MINUTES or -IntervalMinutes. State file:
      AO_REVIEW_TRIGGER_RECONCILE_STATE or %TEMP%\orchestrator-review-reconcile-state.json.
      Each tick:
        1. gh pr list --state open --json number,headRefOid
        2. Get-AoReviewRuns — coverage per PR head SHA (compose with REVIEW RUN
           IDEMPOTENCY above: in-flight, up_to_date, changes_requested count as covered;
           only outdated or absent runs are uncovered)
        3. ao status --json --reports full — resolve worker session and latest accepted
           report for each PR head
        4. gh pr checks + branch-protection required-check names — classify required CI per
           HEAD READY FOR REVIEW (#195; red defers, green/pending eligible, missing routes to
           degraded-CI orchestrator branch)
        5. For each head that is ready for review with a linked worker session: acquire the
           shared review-start claim, run STALE REVIEWER WORKSPACE preflight, PRE-RUN
           HEAD-READY RE-CHECK inside the claim, then ao-review run <worker-session-id>
      Safety (PR #97): never ao spawn, never --claim-pr, never ao session kill, never ao send
      from this process — only ao-review run for a head ready for review. Skip uncovered-but-
      not-ready heads with no worker-lifecycle action. Skip PRs with no linked worker session
      (orchestrator respawn discipline owns session creation). Verification:
        pwsh -NoProfile -File scripts/review-trigger-reconcile.ps1 -Once -DryRun
      See docs/orchestrator-autoloop-go-live.md and docs/orchestrator-recovery-runbook.md.

      DEFERRED-HEAD REVIEW RE-EVALUATION (Issue #235 — scoped supervised child, review-run
      only). When merge.ready defers as uncovered_not_ready / no_ready_for_review (#212),
      scripts/review-trigger-reeval.ps1 watches the small deferred-head set and may
      acquire the shared review-start claim and ao-review run seconds-scale when #195
      readiness lands on the current head SHA.
      Poll classification: scoped_deferred_head_watch (5-minute bounded window; incident
      wake-to-readiness delay ~77 s). Watch state: {stateRoot}/review-trigger-reeval-watch.json.
      Default poll: 5 s (-PollSeconds). Side-effect lock: review-trigger-reeval-side-effect.lock.
      Additive to #207 wake edge and #163 periodic reconcile backstop — not a full-PR sweep.
      Genuinely zero-signal heads (no wake and no in-progress report) remain backstop-only.
      Safety: never ao spawn, --claim-pr, ao session kill, ao send, or merge — only ao-review run.
      Verification:
        pwsh -NoProfile -File scripts/review-trigger-reeval.ps1 -Once -DryRun

      STATE-DERIVED FIRST REVIEW SEND (Issue #202 — REMOVED on AO 0.10).
      scripts/review-send-reconcile.ps1 is a REMOVED stub (exit 2). AO 0.10 auto-delivers
      findings on submit — no ao-review send loop. Delivery confirmation and stuck-open recovery:
        pwsh -NoProfile -File scripts/review-finding-delivery-confirm.ps1
      Default cadence: 5 minutes. See docs/orchestrator-autoloop-go-live.md.

      NAMED PENDING STATE: waiting_worker_review_response.
      A PR enters this state after auto-delivery for a changes_requested run (deliveredAt set,
      deliveredFindingCount > 0), or while any delivered changes_requested run for that PR
      has openFindingCount > 0 and the worker has not yet satisfied an
      exit condition.
      While in waiting_worker_review_response, do NOT treat merge_ready,
      ready_for_review, or stale dashboard metadata as task-complete for that PR.

      EXIT waiting_worker_review_response when ANY of:
        1. Worker reports addressing_reviews via ao report.
        2. Worker pushes a new commit on the PR branch (head SHA advances).
        3. Worker reports terminal failure with a reason (completed with failure note
           or ao send to orchestrator explaining the blocker).
        4. Orchestrator observed the worker session is unavailable, killed it, and
           respawned via ao spawn --project <project> --name '<label>' --claim-pr <PR> (ping/respawn discipline below).
        5. The linked worker PR is merged on GitHub (MERGED PR — REVIEW LOOP TERMINAL
           above; verify via gh pr view, not session status alone).


      TASK CONTINUATION (Issue #430 — issue-keyed, pre- and post-PR). When exactly one live
      issue-bound worker owns the task (ao status issue match + runtime alive) and no prior
      task-continuation tuple was served for the current issue generation, send exactly ONE
      continuation via the gated worker-nudge command (never raw ao send):
        Get-Content -Raw -Path <message-file> | pwsh -NoProfile -File scripts/invoke-gated-worker-nudge.ps1 `
          -SessionId <session> -IssueNumber <issue> -IntentClass task-continuation -Surface orchestrator-turn
        Optional -PrNumber is audit context only after PR open; dedup stays issue-keyed.
        Message file should remind the worker to commit, rebase, open PR, and report when ready.
        Gate version: worker-nudge-gate/v1.

      PING DISCIPLINE (one ping per pending episode). On the next orchestrator turn
      while still in waiting_worker_review_response, if there is no worker
      addressing_reviews report since the send timestamp and no new PR commit, and
      ao events list --json shows no prior ao send ping for this pending episode,
      send exactly ONE message via the gated worker-nudge command (never raw ao send):
        Get-Content -Raw -Path <message-file> | pwsh -NoProfile -File scripts/invoke-gated-worker-nudge.ps1 `
          -SessionId <session> -PrNumber <PR> -HeadSha <head-sha> -ReviewRunId <review-run-id> `
          -IntentClass review-findings -Surface waiting_worker_review_response
        Transport chokepoint: scripts/journaled-worker-send.ps1 (claim token required).
        Message file must hold the reminder to check pending AO review findings (Get-AoReviewRuns),
        report ao report addressing_reviews, or report terminal failure with a reason.
        Gate version: worker-nudge-gate/v1.
      Do NOT send a second ping before observing the next worker response or commit.

      RESPAWN DISCIPLINE. On a later orchestrator turn, if still in
      waiting_worker_review_response with no addressing_reviews, no new commit, and
      a ping was already sent for this episode (visible in ao events list), run:
        ao session kill <session>
        ao spawn --project <project> --name '<label>' --claim-pr <PR>
      Reset ping tracking for the new session.

      REVIEW-READY WORKER STUCK GUARD (Issue #174). On EVERY orchestrator turn,
      BEFORE kill/respawn/claim-pr discipline above for a worker flagged stuck or
      probe_failure, classify one consistent snapshot from ao status --json --reports
      full, gh pr view (current head), gh pr checks (required CI), and Get-AoReviewRuns
      (no pane scraping):
        Linked session owns the PR current head AND runtime alive AND required
        merge-contract CI green on that head AND last accepted ready_for_review is
        for that head AND a review run with status up_to_date and findingCount 0 covers
        the same head/session pair.
        delivered changes_requested does NOT grant protection (mid-fix; Issue #171 owns delivery).
        Red or pending required CI disqualifies protection — use CI FAILURE DISCIPLINE.
      When classified review-ready on false stuck:
        Do NOT immediately ao spawn, --claim-pr, ao session kill, or respawn.
        Hold for bounded grace (default 15 minutes, monotonic per session+head:
        anchored to first false stuck; repeated stuck reports do NOT extend grace).
        Optional helper: docs/review-ready-stuck-guard.mjs (plan/classify stdin JSON).
        Env override: AO_REVIEW_READY_STUCK_GRACE_MINUTES.
      Within grace, recovery requires affirmative unreachability evidence only:
        failed bounded reachability attempt; Issue #171 delivery unconfirmed/escalated
        for the linked run; or Issue #173 terminal_mux_paired_flap still flagged after
        stop-verify. Mere silence (no outbound report) is NOT evidence — do not recover
        on silence alone before grace deadline.
      When evidence exists, prefer careful recycle (ao session kill + operator
      escalation/notify) over blind ao spawn --claim-pr (PR #97 split-brain).
      After grace expires without affirmative unreachable evidence, normal stuck
      handling may resume.
      Genuine death (runtime not alive) is NOT shielded — orphan/respawn (#98) applies.
      Operator adoption: merge this block into live orchestratorRules, then ao stop
      and ao start. See docs/orchestrator-recovery-runbook.md (Review-ready worker
      false stuck).

      ROUND PROGRESSION after worker fixes. When the PR head SHA advances past the
      last review run's target SHA, apply HEAD READY FOR REVIEW (#195) and PRE-RUN
      HEAD-READY RE-CHECK, then ao-review run <session> for the next round only when the new head is ready for review — do not
      ask the operator. Intermediate commits while the worker is still fixing must not trigger
      a review run.

      ROUND LIMIT (prompt-level stop). Count completed review runs for the current PR
      from Get-AoReviewRuns where findingCount > 0 OR openFindingCount > 0.
      After 20 such runs, stop initiating new review→fix cycles on that PR: emit a
      human notification (notify-class action) with PR number and round count; do
      not respawn or continue the loop.

      OPERATOR ADOPTION HANDOFF (Issue #101). When a worker PR is merge-ready or
      mergeable per the rules below (required CI green, up_to_date review, worker
      ready_for_review), before assuming the autonomous loop is fully live for the
      next spawn, remind the operator: execute the ## Operator adoption checklist
      from that PR body and the matching docs/migration_notes.md subsection.
      Workers document adoption; the operator owns live agent-orchestrator.yaml,
      listeners, env, and ao stop / ao start. Do not treat merged example YAML or
      migration prose as executed until the operator confirms.

      NO MERGE BY ORCHESTRATOR. Never call gh pr merge or click Merge. Merge is
      operator-only — no AO-managed agent performs or directs a PR merge. Also
      MUST NOT direct, instruct, ask, nudge, or otherwise prompt any worker or
      other agent to merge; proceed-to-merge or go-ahead-and-merge messages to a
      worker are forbidden.
      The approved-and-green / merge.ready completion wake is a hand-off addressed
      to the operator (human), not a cue to merge. On that wake, when the ALL-true
      gate below holds, emit the ready-for-human-merge notification to the
      operator and stop at the merge boundary — do not merge and do not delegate
      the merge.
      Emit ready-for-human-merge notification only when ALL are true:
        - Latest AO-local review run for current PR head has findingCount: 0 and up_to_date status
          (no open or sent findings remain);
        - PR is open with required CI green on the same head SHA (see REQUIRED CI);
        - Worker reported ready_for_review for current head, OR the latest clean
          review completed after the worker's latest ready_for_review with no newer
          commits;
        - No later changes-requested, ci-failed, or failed review run for that head.

      Operator input is required only for merge, round-limit escalation, or
      unrecoverable worker/reviewer failure — not between review rounds.

# Review model policy:
# - Desired reviewer: Codex CLI with model gpt-5.5.
# - Current upstream AO schema supports orchestrator and worker role config directly.
# - Keep Codex reviewer integration upgrade-safe: implement it as an external plugin/workflow
#   under plugins/** or CI, never as a packages/core patch.

# CI-FAILURE REACTION RECORD (Issue #342 — executable wiring; not orchestratorRules prose):
# Side-process supervisor child ci-failure-notification-reaction records pending episodes:
#   pwsh -NoProfile -File scripts/ci-failure-notification-reaction.ps1
# Delivery evaluation remains in ci-failure-notification-reconcile.ps1 (ao send only there).

reactions:
  ci-failed:
    auto: true
    action: notify
    message: >-
      Red CI enqueued for pack ci-failure-notification reconcile delivery (Issue #342).
      Pending episode record runs via ci-failure-notification-reaction.ps1; worker ping
      is never sent from this reaction path.
    priority: action
  changes-requested:
    auto: true
    action: send-to-agent
    escalateAfter: 30m
  approved-and-green:
    auto: false
    action: notify
    priority: action
  report-stale:
    auto: true
    action: send-to-agent
    message: >-
      Worker idle (report-stale backstop). Check pending AO review findings via
      `Get-AoReviewRuns` and report `ao report addressing_reviews`, or report a
      terminal failure with a reason. Do not stay silent after review findings land.

# Upgrade-safe extension notes:
# - Implement task declaration, runtime scope guard, and token chain ledger through
#   AO plugin slots, wrappers, hooks, external state, and CI.
# - Do not patch Composio AO packages/core.
# - PR CI scope validation is the second line of defense; runtime guard is first.

# AO 0.10 review harness (Issue #623)
# On AO 0.10.x, configure reviewers via project config API — not REVIEW_COMMAND/--command:
#   ao project set-config orchestrator-pack --config-json '{"reviewers":[{"harness":"codex"}]}'
# Pack trigger loop uses POST /api/v1/sessions/{workerId}/reviews/trigger (scripts/ao-review.ps1 shim).
# Operator adoption: docs/ao-0-10-review-harness-adoption.md

