    {
      "id": "issue-view-body",
      "ownerClass": "rest_inventory",
      "canonical": "gh issue view N --json body",
      "routeId": "issue-view-body",
      "ownerIssue": 431
    },
    {
      "id": "issue-view-rca-metadata",
      "ownerClass": "rest_inventory",
