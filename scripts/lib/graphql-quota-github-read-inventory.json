    {
      "id": "repo-view-nameWithOwner",
      "ownerClass": "rest_inventory",
      "canonical": "gh repo view --json nameWithOwner",
      "routeId": "repo-view-name-with-owner",
      "ownerIssue": 431
    },
    {
      "id": "gh-api-graphql-passthrough",
      "ownerClass": "graphql_fail_fast",
      "canonical": "gh api graphql",
      "ownerIssue": 540,
      "policy": "pack scripts/gh passthrough fail-fast after primary GraphQL quota exhaustion"
    },
    {
      "id": "rest-repos-issues-events",
      "ownerClass": "rest_direct",
      "pattern": "^gh api repos/(?:[^/\\s]+/){1,2}issues/[^/\\s]+/events(?:\\s|$)",
      "ownerIssue": 453
    },
    {
      "id": "rest-repos-collaborators-permission",
      "ownerClass": "rest_direct",
      "pattern": "^gh api repos/(?:[^/\\s]+/){1,2}collaborators/[^/\\s]+/permission(?:\\s|$)",
      "ownerIssue": 453
    },
    {
      "id": "rest-repos-branches-protection",
      "ownerClass": "rest_direct",
      "pattern": "^gh api repos/(?:[^/\\s]+/){1,2}branches/[^/\\s]+/protection(?:\\s|$)",
      "ownerIssue": 453
    },
    {
      "id": "rest-repos-pulls-number",
      "ownerClass": "rest_direct",
      "pattern": "^gh api repos/(?:[^/\\s]+/){1,2}pulls/[^/\\s]+(?:\\s|$)",
      "ownerIssue": 546
    },
    {
      "id": "rest-repos-commits-sha",
      "ownerClass": "rest_direct",
      "pattern": "^gh api repos/(?:[^/\\s]+/){1,2}commits/[^/\\s]+(?:\\s|$)",
