      "routeId": "pr-view",
      "ownerIssue": 501
    },
    {
      "id": "pr-view-baseRefName",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr view N --json baseRefName",
      "routeId": "pr-view",
      "ownerIssue": 431
    },
    {
      "id": "pr-view-headRefOid-headRefName",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr view N --json headRefOid,headRefName",
      "routeId": "pr-view",
      "ownerIssue": 546
    },
    {
      "id": "pr-view-headRefOid-baseRefName-number-state",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr view N --json number,headRefOid,baseRefName,state",
      "routeId": "pr-view",
      "ownerIssue": 431
    },
    {
      "id": "pr-view-body-number",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr view N --json number,body",
      "routeId": "pr-view",
      "ownerIssue": 431
    },
    {
      "id": "pr-view-prInfoFromView",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr view N --json baseRefName,headRefName,isDraft,number,title,url",
      "routeId": "pr-view",
      "ownerIssue": 530
    },
    {
      "id": "pr-checks-inventory",
      "ownerClass": "rest_inventory",
