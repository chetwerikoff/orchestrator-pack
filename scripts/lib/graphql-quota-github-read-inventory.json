{
  "version": "graphql-quota-github-read-inventory/v1",
  "ownerClasses": [
    "rest_inventory",
    "graphql_fail_fast",
    "rest_direct",
    "accepted_upstream_residual"
  ],
  "scanSurfaces": {
    "reconcile": [
      "scripts/lib/Gh-PrChecks.ps1",
      "scripts/lib/Gh-FleetInventoryCache.ps1",
      "scripts/lib/Get-AutoReviewPrContext.ps1",
      "scripts/lib/Autonomous-SpawnWorktreeGate.ps1",
      "scripts/lib/Ci-Failure-Notification-Common.ps1",
      "scripts/pr-scope-check.ps1"
    ],
    "rules": [
      "prompts/agent_rules.md",
      "prompts/investigate_root_cause.md",
      "agent-orchestrator.yaml.example"
    ]
  },
  "rows": [
    {
      "id": "pr-list-open-headRefOid-number",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr list --state open --json number,headRefOid --limit 200",
      "routeId": "pr-list-open",
      "ownerIssue": 431
    },
    {
      "id": "pr-list-open-headRefOid-baseRefName-number",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr list --state open --json number,headRefOid,baseRefName --limit 200",
      "routeId": "pr-list-open",
      "ownerIssue": 431
    },
    {
      "id": "pr-list-head-number-jq",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr list --head BRANCH --json number --limit 1 --jq .[0].number",
      "routeId": "pr-list-head",
      "ownerIssue": 443
    },
    {
      "id": "pr-list-head-number-url",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr list --head BRANCH --json number,url --limit 1",
      "routeId": "pr-list-head",
      "ownerIssue": 443
    },
    {
      "id": "pr-list-merged-closes",
      "ownerClass": "rest_inventory",
      "canonical": "gh pr list --state merged --search \"closes #N\" --json number,title,state,mergedAt --limit 10",
      "routeId": "pr-list-merged-closes",
      "ownerIssue": 520
    },
    {
      "id": "pr-view-state-only",
      "ownerClass": "rest_inventory",
