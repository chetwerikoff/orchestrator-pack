#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "$0")/.." && pwd)"
state=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --state) state="${2:-}"; shift 2 ;;
    --state=*) state="${1#--state=}"; shift ;;
    -*) shift ;;
    *)
      if [[ -z "$state" ]]; then
        state="$1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$state" ]]; then
  exit 0
fi

exec pwsh -NoProfile -File "$root/scripts/pack-worker-report.ps1" "$state" "$@"
