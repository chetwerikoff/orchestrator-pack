#!/usr/bin/env bash
# Pack git shim for autonomous orchestrator sessions (Issue #324).
# Prepend this scripts/ directory to PATH for orchestrator agentConfig only.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_pwsh() {
  if [[ -n "${AO_PWSH_BINARY:-}" && -x "${AO_PWSH_BINARY}" ]]; then
    printf '%s\n' "${AO_PWSH_BINARY}"
    return 0
  fi
  if command -v pwsh >/dev/null 2>&1; then
    command -v pwsh
    return 0
  fi
  local candidate
  for candidate in     /usr/local/bin/pwsh     /usr/bin/pwsh     /opt/microsoft/powershell/7/pwsh     "${HOME}/.local/bin/pwsh"; do
    if [[ -x "${candidate}" ]]; then
      printf '%s\n' "${candidate}"
      return 0
    fi
  done
  printf 'pwsh\n'
}

GUARD="$SCRIPT_DIR/git-autonomous-guard.ps1"

if [[ "${AO_AUTONOMOUS_ORCHESTRATOR_SURFACE:-}" == "1" ]]; then
  exec "$(resolve_pwsh)" -NoProfile -ExecutionPolicy Bypass -File "$GUARD" "$@"
fi

resolve_real_git() {
  local pack_root config candidate resolved dir self
  pack_root="$(cd "${SCRIPT_DIR}/.." && pwd)"
  config="${pack_root}/.ao/autonomous-real-binaries.json"
  if [[ -f "${config}" ]]; then
  local git_path
    git_path="$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('git',''))" "${config}" 2>/dev/null || true)"
    if [[ -n "${git_path}" && -x "${git_path}" ]]; then
      printf '%s\n' "${git_path}"
      return 0
    fi
  fi

  if [[ -n "${GIT_REAL_BINARY:-}" && "${GIT_REAL_BINARY}" != "git" ]]; then
    if [[ -x "${GIT_REAL_BINARY}" ]]; then
      printf '%s\n' "${GIT_REAL_BINARY}"
      return 0
    fi
    if command -v "${GIT_REAL_BINARY}" >/dev/null 2>&1; then
      command -v "${GIT_REAL_BINARY}"
      return 0
    fi
  fi

  self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
  IFS=':' read -ra path_dirs <<< "${PATH:-}"
  for dir in "${path_dirs[@]}"; do
    [[ -z "${dir}" || "${dir}" == "${SCRIPT_DIR}" ]] && continue
    candidate="${dir%/}/git"
    [[ -x "${candidate}" ]] || continue
    resolved="$(readlink -f "${candidate}" 2>/dev/null || realpath "${candidate}" 2>/dev/null || printf '%s' "${candidate}")"
    if [[ "${resolved}" != "${self}" && "${resolved}" != *git-autonomous-guard* ]]; then
      printf '%s\n' "${resolved}"
      return 0
    fi
  done

  printf 'git\n'
}

exec "$(resolve_real_git)" "$@"
