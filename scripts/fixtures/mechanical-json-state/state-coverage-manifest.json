{
  "jsExempt": [
    {
      "path": "/tmp/orchestrator-wake-dedup.json",
      "owner": "docs/orchestrator-wake-filter.mjs",
      "reason": "JS-owned dedup state is outside the PowerShell hashtable reflection class"
    },
    {
      "childId": "review-start-claim-reaper",
      "path": "{project}/review-start-claims",
      "owner": "scripts/lib/Review-StartClaim.ps1",
      "reason": "Stateless periodic sweeper; claim lifecycle state lives in the canonical claim namespace (active/terminal/audit dirs), not mechanical JSON reconcile state"
    },
    {
      "childId": "ci-failure-notification-reconcile",
      "path": "{temp}/orchestrator-ci-failure-notification",
      "owner": "docs/ci-failure-notification.mjs",
      "reason": "Episode pending/terminal store is file-based under node helper episodes/tokens/audit dirs, outside PowerShell mechanical JSON state helper"
    }
  ],
  "children": [
    {
      "id": "ci-green-wake-reconcile",
      "stateFile": "orchestrator-ci-green-wake-state.json",
      "callerScripts": [
        "scripts/ci-green-wake-reconcile.ps1"
      ],
      "mapFields": [
        "heads",
        "nudged",
        "pendingJournal"
      ],
      "actionTracking": true
    },
    {
      "id": "review-trigger-reconcile",
      "stateFile": "orchestrator-review-trigger-reconcile-state.json",
      "callerScripts": [
        "scripts/review-trigger-reconcile.ps1",
        "scripts/lib/Invoke-ReviewWakeTrigger.ps1"
      ],
      "mapFields": [
        "degradedCi",
        "cycleState"
      ],
      "actionTracking": true
    },
    {
      "id": "worker-message-submit-reconcile",
      "stateFile": "orchestrator-worker-message-submit-state.json",
      "callerScripts": [
        "scripts/worker-message-submit-reconcile.ps1"
      ],
      "mapFields": [
        "deliveries"
      ],
      "actionTracking": true
    },
    {
      "id": "review-trigger-reeval",
      "stateFile": "review-trigger-reeval-watch.json",
      "callerScripts": [
        "scripts/lib/Record-ReviewTriggerReevalWatch.ps1"
      ],
      "mapFields": [
        "watchEntries"
      ],
      "actionTracking": true
    },
    {
      "id": "worker-message-dispatch-journal",
      "stateFile": "orchestrator-worker-message-dispatch-journal.json",
      "callerScripts": [
        "scripts/lib/Record-WorkerMessageDispatch.ps1"
      ],
      "mapFields": [
        "deliveryId"
      ],
      "actionTracking": true,
      "bespoke": true
    },
    {
      "id": "review-handoff-wake-admission",
      "stateFile": "review-handoff-wake-admission.json",
      "callerScripts": [
        "scripts/lib/Record-ReviewHandoffWakeAdmission.ps1"
      ],
      "mapFields": [
        "records",
        "pendingRetries"
      ],
      "actionTracking": true
    },
    {
      "id": "review-ready-report-state-seed",
      "stateFile": "review-ready-report-state-seed-state.json",
      "callerScripts": [
        "scripts/lib/Record-ReviewReadyReportStateSeed.ps1"
      ],
      "mapFields": [
        "bindingByKey",
        "seededKeys",
        "deferredScanKeys"
      ],
      "actionTracking": true
    },
    {
      "id": "dead-worker-reconcile",
      "stateFile": "orchestrator-dead-worker-reconcile-state.json",
      "callerScripts": [
        "scripts/dead-worker-reconcile.ps1",
        "scripts/clear-dead-worker-reconcile-quarantine.ps1"
      ],
      "mapFields": [
        "attempts",
        "leases",
        "pendingActions",
        "quarantinedActions"
      ],
      "actionTracking": true
    },
    {
      "id": "escalation-router",
      "stateFile": "orchestrator-escalation-state.json",
      "callerScripts": [
        "scripts/lib/Orchestrator-Escalation.ps1",
        "scripts/orchestrator-escalation-router.ps1"
      ],
      "mapFields": [
        "records",
        "wakeWindows"
      ],
      "actionTracking": true
    }
  ]
}
