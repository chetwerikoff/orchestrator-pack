        "AO_ESCALATION_HEALTH_SPOOL"
      ],
      "canonicalDefault": "${TMP}/orchestrator-escalation-health",
      "liveRoot": "${TMP}",
      "sidecars": [],
      "harnessPath": "health-spool",
      "sourceFiles": [
        "scripts/lib/Orchestrator-Escalation.ps1"
      ],
      "excluded": false,
      "exclusionReason": null
