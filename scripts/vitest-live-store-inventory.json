{
  "schemaVersion": 1,
  "issue": 752,
  "allowedRoots": [
    "scripts/**",
    "plugins/**",
    "vitest.config.ts",
    "package.json",
    ".github/workflows/**",
    "docs/**"
  ],
  "liveRoots": [
    {
      "id": "wake-supervisor-state-root",
      "defaultTemplate": "${HOME}/.local/state/orchestrator-pack-wake-supervisor",
      "harnessEnv": "ORCHESTRATOR_PACK_WAKE_SUPERVISOR_STATE_DIR",
      "kind": "directory"
    },
    {
      "id": "ao-base-root",
      "defaultTemplate": "${HOME}/.agent-orchestrator",
      "harnessEnv": "AO_BASE_DIR",
      "kind": "directory"
    }
  ],
  "stores": [
    {
      "id": "orchestrator-escalation-state",
      "kind": "file",
      "resolver": "Get-OrchestratorEscalationStatePath",
      "writeBoundary": "Publish-OrchestratorEscalation / Set-MechanicalJsonStateFile",
      "envOverrides": [
        "AO_ORCHESTRATOR_ESCALATION_STATE"
      ],
      "canonicalDefault": "${TMP}/orchestrator-escalation-state.json",
      "liveRoot": "${TMP}",
      "sidecars": [
        "orchestrator-escalation-state.json.tmp",
        "orchestrator-escalation-state.json.bak",
        "orchestrator-escalation-state.json.corrupt-*",
        "orchestrator-escalation-state.json.lock"
      ],
      "harnessPath": "state/orchestrator-escalation-state.json",
      "sourceFiles": [
        "scripts/lib/Orchestrator-Escalation.ps1"
      ],
      "excluded": false,
      "exclusionReason": null
    },
    {
      "id": "orchestrator-operator-inbox",
      "kind": "directory",
      "resolver": "Get-OrchestratorEscalationOperatorInboxDir",
      "writeBoundary": "Publish-OrchestratorEscalation operator route",
      "envOverrides": [
        "AO_OPERATOR_ESCALATION_INBOX"
      ],
      "canonicalDefault": "${TMP}/orchestrator-operator-inbox",
      "liveRoot": "${TMP}",
      "sidecars": [],
      "harnessPath": "operator-inbox",
      "sourceFiles": [
        "scripts/lib/Orchestrator-Escalation.ps1"
      ],
      "excluded": false,
      "exclusionReason": null
    },
    {
      "id": "orchestrator-escalation-health-spool",
