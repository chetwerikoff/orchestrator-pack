      "id": "worker-nudge-claim-namespace",
      "kind": "directory",
      "resolver": "Resolve-WorkerNudgeClaimNamespace",
      "writeBoundary": "Worker-NudgeClaim claim/terminal writes",
      "envOverrides": [
