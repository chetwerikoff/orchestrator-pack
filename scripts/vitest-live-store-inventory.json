  ],
  "exclusions": [
    {
      "id": "repo-fixtures-and-golden-files",
      "reason": "Tracked test fixtures are immutable repository inputs and have no runtime live-default resolver or write seam."
    },
    {
      "id": "vitest-runtime-reports",
      "reason": "Repository-local CI artifacts are invocation outputs, not operator live stores; they are already scoped to the current checkout and removed/replaced by lane wrappers."
    }
  ]
}
