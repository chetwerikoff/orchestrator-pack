      "sidecars": [
        "worker-message-submit-state-root.anchor.json.tmp"
      ],
      "harnessPath": "wake/worker-message-submit-state-root.anchor.json",
      "sourceFiles": [
        "scripts/worker-message-submit-reconcile.ps1"
