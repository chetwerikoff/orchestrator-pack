{
  "scanPaths": [
    "prompts/**",
    "scripts/**",
    "plugins/**",
    "docs/**",
    ".github/**",
    ".cursor/skills/**"
  ],
  "excludePaths": [
    "tests/fixtures/**",
    "scripts/fixtures/**",
    "vendor/**",
    "packages/core/**",
    ".ao/**",
    "docs/declarations/**",
    "node_modules/**",
    "scripts/vitest-heavy-topology.plan.json",
    "scripts/contract-evidence-validator.mjs",
    "scripts/contract-evidence-validator.d.mts",
    "scripts/gate-runner/census/**"
  ],
  "scriptExtensions": [
    ".ps1",
    ".sh",
    ".bash",
    ".js",
    ".ts",
    ".mjs",
    ".cjs"
  ],
  "templateExtensions": [
    ".md",
    ".yaml",
    ".yml",
    ".json",
    ".example",
    ".template",
    ".tpl"
  ],
  "duplicateLiteralMinLines": 10,
  "pairedEditMinLines": 8,
  "pairedLineStride": 2,
  "heuristicMinLines": 3,
  "heuristicMaxLines": 9,
  "similarityThreshold": 0.85,
  "heuristicLineStride": 3,
  "heuristicMaxFindings": 25,
  "heuristicMaxFileLines": 300,
  "pairedOverlapMinLines": 6,
  "pairedOverlapMinRatio": 0.75,
  "suppressions": [
    {
      "rule": "duplicate-literal",
      "files": [
        "docs/ao-0-10-review-api.mjs",
        "scripts/pr2-foundation/terminalized/ao-0-10-review-api.ts"
