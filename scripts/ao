#!/usr/bin/env bash
# Pack ao shim for autonomous orchestrator sessions (Issue #318).
# Prepend this scripts/ directory to PATH for orchestrator agentConfig only.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# shellcheck disable=SC1091
. "${SCRIPT_DIR}/_resolve-pwsh.sh"

GUARD="$SCRIPT_DIR/ao-autonomous-guard.ps1"

# shellcheck disable=SC1091
. "${SCRIPT_DIR}/lib/autonomous-guard-fast-path.sh"

__ao_autonomous_warn_explicit_ao_config_misconfiguration() {
  local reason="$1"
  local config_path="$2"
  local configured_path="${3:-}"
  if [[ -n "${__AO_AUTONOMOUS_EXPLICIT_AO_MISCONFIG_WARNED:-}" ]]; then
    return 0
  fi
  export __AO_AUTONOMOUS_EXPLICIT_AO_MISCONFIG_WARNED=1
  local example_doc="docs/autonomous-real-binaries.example.json"
  if [[ "${reason}" == "invalid-json" ]]; then
    printf 'autonomous real-binary config: invalid JSON (config: %s; see %s)\n' "${config_path}" "${example_doc}" >&2
    return 0
  fi
  printf 'autonomous real-binary config: explicit ao pointer missing or not executable: %s (config: %s; see %s)\n' "${configured_path}" "${config_path}" "${example_doc}" >&2
}

__ao_autonomous_configured_ao_pointer_usable() {
  local candidate="$1"
  local resolved self
  [[ -n "${candidate}" && "${candidate}" != "ao" ]] || return 1
  [[ -x "${candidate}" ]] || return 1
  resolved="$(readlink -f "${candidate}" 2>/dev/null || realpath "${candidate}" 2>/dev/null || printf '%s' "${candidate}")"
  self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
  [[ "${resolved}" != "${self}" && "${resolved}" != *ao-autonomous-guard* ]] || return 1
  return 0
}

resolve_real_ao() {
  local pack_root config ao_path
  pack_root="$(cd "${SCRIPT_DIR}/.." && pwd)"
  config="${pack_root}/.ao/autonomous-real-binaries.json"
  if [[ -f "${config}" ]]; then
    ao_path=""
    if ao_path="$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('ao',''))" "${config}" 2>/dev/null)"; then
      :
    elif [[ "${AO_AUTONOMOUS_ORCHESTRATOR_SURFACE:-}" == "1" ]]; then
      __ao_autonomous_warn_explicit_ao_config_misconfiguration invalid-json "${config}"
    fi
    if [[ -n "${ao_path}" ]]; then
      if __ao_autonomous_configured_ao_pointer_usable "${ao_path}"; then
        printf '%s\n' "${ao_path}"
        return 0
      fi
      if [[ "${AO_AUTONOMOUS_ORCHESTRATOR_SURFACE:-}" == "1" ]]; then
        __ao_autonomous_warn_explicit_ao_config_misconfiguration broken-pointer "${config}" "${ao_path}"
      fi
    fi
  fi

  if [[ "${AO_AUTONOMOUS_ORCHESTRATOR_SURFACE:-}" != "1" ]]; then
    if [[ -n "${AO_REAL_BINARY:-}" && "${AO_REAL_BINARY}" != "ao" ]]; then
      if [[ -x "${AO_REAL_BINARY}" ]]; then
        printf '%s\n' "${AO_REAL_BINARY}"
        return 0
      fi
      if command -v "${AO_REAL_BINARY}" >/dev/null 2>&1; then
        command -v "${AO_REAL_BINARY}"
        return 0
      fi
    fi
  fi

  local self dir candidate resolved
  self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || realpath "${BASH_SOURCE[0]}" 2>/dev/null || printf '%s' "${BASH_SOURCE[0]}")"
  IFS=':' read -ra path_dirs <<< "${PATH:-}"
  for dir in "${path_dirs[@]}"; do
    [[ -z "${dir}" || "${dir}" == "${SCRIPT_DIR}" ]] && continue
    candidate="${dir%/}/ao"
    [[ -x "${candidate}" ]] || continue
    resolved="$(readlink -f "${candidate}" 2>/dev/null || realpath "${candidate}" 2>/dev/null || printf '%s' "${candidate}")"
    if [[ "${resolved}" != "${self}" && "${resolved}" != *ao-autonomous-guard* ]]; then
      printf '%s\n' "${resolved}"
      return 0
    fi
  done

  for fallback in "${HOME}/.local/bin/ao" "${HOME}/.npm-global/bin/ao" "${HOME}/.ao/bin/ao"; do
    if [[ -x "${fallback}" ]]; then
      printf '%s\n' "${fallback}"
      return 0
    fi
  done

  printf 'ao\n'
}

if [[ "${AO_AUTONOMOUS_ORCHESTRATOR_SURFACE:-}" == "1" ]]; then
  if __ao_autonomous_ao_argv_is_read_fast_path "$@"; then
    exec "$(resolve_real_ao)" "$@"
  fi
  __ao_autonomous_audit_guard_pwsh_spawn "ao"
  exec "$(resolve_pwsh)" -NoProfile -ExecutionPolicy Bypass -File "$GUARD" "$@"
fi

exec "$(resolve_real_ao)" "$@"
